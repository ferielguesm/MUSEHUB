{% extends 'front/base.html.twig' %}

{% block title %}Assistant MuseHub{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }
    .chatbot-container {
        max-width: 800px;
        margin: 2rem auto;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    .chatbot-header {
        background: linear-gradient(135deg, #7f00ff, #ff9cb6);
        color: white;
        padding: 20px;
        text-align: center;
    }
    .chat-messages {
        height: 500px;
        overflow-y: auto;
        padding: 20px;
        background: #f8fafc;
    }
    .message {
        margin-bottom: 20px;
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }
    .message.bot .avatar {
        background: linear-gradient(135deg, #7f00ff, #ff9cb6);
        color: white;
    }
    .message.user {
        flex-direction: row-reverse;
    }
    .message.user .message-content {
        background: linear-gradient(135deg, #7f00ff, #ff9cb6);
        color: white;
    }
    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        flex-shrink: 0;
    }
    .message-content {
        background: white;
        padding: 12px 16px;
        border-radius: 18px;
        max-width: 70%;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        white-space: pre-line;
    }
    .message.user .message-content {
        text-align: right;
    }
    .chat-input-area {
        padding: 20px;
        background: white;
        border-top: 1px solid #e5e7eb;
    }
    .input-group {
        display: flex;
        gap: 12px;
    }
    .chat-input {
        flex: 1;
        border: 2px solid #e5e7eb;
        border-radius: 25px;
        padding: 12px 20px;
        font-size: 16px;
        outline: none;
        transition: border-color 0.3s ease;
    }
    .chat-input:focus {
        border-color: #7f00ff;
        box-shadow: 0 0 0 3px rgba(127, 0, 255, 0.1);
    }
    .send-btn {
        background: linear-gradient(135deg, #7f00ff, #ff9cb6);
        border: none;
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: transform 0.2s ease;
    }
    .send-btn:hover {
        transform: scale(1.05);
    }
    .send-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }
    .typing-indicator {
        display: none;
        font-style: italic;
        color: #6b7280;
        padding: 8px 16px;
    }
    .suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
    }
    .suggestion-btn {
        background: #f3f4f6;
        border: 1px solid #d1d5db;
        border-radius: 20px;
        padding: 6px 12px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .suggestion-btn:hover {
        background: #e5e7eb;
        border-color: #9ca3af;
    }
    .escalation-notice {
        background: #fef3c7;
        border: 1px solid #f59e0b;
        border-radius: 8px;
        padding: 12px;
        margin-top: 12px;
        color: #92400e;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="chatbot-container">
        <div class="chatbot-header">
            <h2 class="mb-1">🤖 Assistant MuseHub</h2>
            <p class="mb-0 opacity-75">Votre guide pour la communauté</p>
        </div>

        <div class="chat-messages" id="chatMessages">
            <div class="message bot">
                <div class="avatar">🤖</div>
                <div class="message-content" id="welcomeMessage">
                    Chargement...
                </div>
            </div>
        </div>

        <div class="chat-input-area">
            <div class="suggestions" id="suggestions"></div>

            <form class="input-group" id="chatForm">
                <input type="text" class="chat-input" id="messageInput" placeholder="Posez votre question..." maxlength="500" autocomplete="off">
                <button type="submit" class="send-btn" id="sendButton">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>

            <div class="typing-indicator" id="typingIndicator">
                <i class="fas fa-circle-notch fa-spin me-2"></i>Assistant réfléchit...
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const chatMessages = document.getElementById('chatMessages');
    const messageInput = document.getElementById('messageInput');
    const chatForm = document.getElementById('chatForm');
    const sendButton = document.getElementById('sendButton');
    const typingIndicator = document.getElementById('typingIndicator');
    const suggestionsContainer = document.getElementById('suggestions');

    let isLoading = false;

    // Load welcome message
    fetchWelcomeMessage();

    // Handle form submission
    chatForm.addEventListener('submit', function(e) {
        e.preventDefault();
        sendMessage();
    });

    // Handle enter key
    messageInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // Handle suggestion clicks
    suggestionsContainer.addEventListener('click', function(e) {
        if (e.target.classList.contains('suggestion-btn')) {
            messageInput.value = e.target.textContent;
            sendMessage();
        }
    });

    async function fetchWelcomeMessage() {
        try {
            const response = await fetch('{{ path("api_chatbot_welcome") }}');
            const data = await response.json();

            document.getElementById('welcomeMessage').textContent = data.message;
        } catch (error) {
            console.error('Error loading welcome message:', error);
            document.getElementById('welcomeMessage').textContent = 'Bienvenue sur MuseHub ! Comment puis-je vous aider ?';
        }
    }

    async function sendMessage() {
        const message = messageInput.value.trim();
        if (!message || isLoading) return;

        // Add user message to chat
        addMessage(message, 'user');

        // Clear input and disable
        messageInput.value = '';
        setLoading(true);

        try {
            const response = await fetch('{{ path("api_chatbot_message") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ message: message }),
                credentials: 'same-origin'
            });

            const data = await response.json();

            if (response.ok) {
                // Add bot response
                addMessage(data.response, 'bot', data.escalated);

                // Show suggestions if available
                if (data.suggestions && data.suggestions.length > 0) {
                    showSuggestions(data.suggestions);
                } else {
                    hideSuggestions();
                }
            } else {
                addMessage('Désolé, une erreur s\'est produite. Veuillez réessayer.', 'bot');
                hideSuggestions();
            }
        } catch (error) {
            console.error('Error sending message:', error);
            addMessage('Erreur de connexion. Vérifiez votre connexion internet et réessayez.', 'bot');
            hideSuggestions();
        }

        setLoading(false);
        messageInput.focus();
    }

    function addMessage(content, type, escalated = false) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${type}`;

        const avatar = type === 'bot' ? '🤖' : '👤';
        const avatarClass = type === 'bot' ? 'bot' : 'user';

        messageDiv.innerHTML = `
            <div class="avatar ${avatarClass}">${avatar}</div>
            <div class="message-content">${escapeHtml(content)}</div>
        `;

        if (escalated) {
            const notice = document.createElement('div');
            notice.className = 'escalation-notice';
            notice.innerHTML = '<i class="fas fa-exclamation-triangle me-2"></i>Un modérateur a été notifié de votre message.';
            messageDiv.appendChild(notice);
        }

        chatMessages.appendChild(messageDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showSuggestions(suggestions) {
        suggestionsContainer.innerHTML = '';
        suggestions.forEach(suggestion => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'suggestion-btn';
            button.textContent = suggestion;
            suggestionsContainer.appendChild(button);
        });
    }

    function hideSuggestions() {
        suggestionsContainer.innerHTML = '';
    }

    function setLoading(loading) {
        isLoading = loading;
        sendButton.disabled = loading;
        messageInput.disabled = loading;

        if (loading) {
            typingIndicator.style.display = 'block';
            sendButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        } else {
            typingIndicator.style.display = 'none';
            sendButton.innerHTML = '<i class="fas fa-paper-plane"></i>';
        }
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
});
</script>
{% endblock %}
