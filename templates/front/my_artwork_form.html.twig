{% extends 'front/base.html.twig' %}

{% block title %}
    {{ action == 'new' ? 'Créer une œuvre' : 'Modifier une œuvre' }} - MuseHub
{% endblock %}

{% block body %}
<div class="container my-5">
    {# Header #}
    <div class="mb-4">
        <a href="{{ path('my_artworks_list') }}" class="btn btn-outline-secondary btn-sm rounded-pill mb-3">
            <i class="fas fa-arrow-left me-2"></i>Retour à mes œuvres
        </a>
        
        <h1 class="h2 mb-1">
            <i class="fas fa-{{ action == 'new' ? 'plus-circle' : 'edit' }} me-2 text-primary"></i>
            {{ action == 'new' ? 'Créer une œuvre' : 'Modifier une œuvre' }}
        </h1>
        <p class="text-muted mb-0">
            {{ action == 'new' ? 'Partagez votre art avec la communauté' : 'Mettez à jour les informations de votre œuvre' }}
        </p>
    </div>

    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Form Card #}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="row g-4">
                    {# Title #}
                    <div class="col-12">
                        <label class="form-label fw-bold">
                            <i class="fas fa-heading text-primary me-2"></i>{{ form_label(form.title) }}
                        </label>
                        {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg'}}) }}
                        <small class="text-muted">{{ form_help(form.title) }}</small>
                        {{ form_errors(form.title) }}
                    </div>

                    {# Description #}
                    <div class="col-12">
                        <label class="form-label fw-bold">
                            <i class="fas fa-align-left text-primary me-2"></i>{{ form_label(form.description) }}
                        </label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                        <small class="text-muted">{{ form_help(form.description) }}</small>
                        {{ form_errors(form.description) }}
                    </div>

                    {# Price and Category #}
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            <i class="fas fa-euro-sign text-primary me-2"></i>{{ form_label(form.price) }}
                        </label>
                        {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
                        <small class="text-muted">{{ form_help(form.price) }}</small>
                        {{ form_errors(form.price) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            <i class="fas fa-tag text-primary me-2"></i>{{ form_label(form.category) }}
                        </label>
                        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                        <small class="text-muted">{{ form_help(form.category) }}</small>
                        {{ form_errors(form.category) }}
                    </div>

                    {# Status #}
                    <div class="col-12">
                        <label class="form-label fw-bold">
                            <i class="fas fa-eye text-primary me-2"></i>{{ form_label(form.status) }}
                        </label>
                        <div class="d-flex gap-3 mt-2">
                            {{ form_widget(form.status) }}
                        </div>
                        <small class="text-muted d-block mt-2">{{ form_help(form.status) }}</small>
                        {{ form_errors(form.status) }}
                    </div>

                    {# Current Image (Edit mode) #}
                    {% if action == 'edit' and artwork and artwork.imageUrl %}
                        <div class="col-12">
                            <label class="form-label fw-bold">
                                <i class="fas fa-image text-primary me-2"></i>Image actuelle
                            </label>
                            <div class="mt-2">
                                <img src="{{ artwork.imageUrl }}" alt="{{ artwork.title }}" 
                                     class="img-thumbnail" style="max-width: 300px; max-height: 300px; object-fit: cover;">
                            </div>
                        </div>
                    {% endif %}

                    {# Image Upload #}
                    <div class="col-12">
                        <label class="form-label fw-bold">
                            <i class="fas fa-upload text-primary me-2"></i>{{ form_label(form.imageFile) }}
                            {% if action == 'new' %}
                                <span class="text-danger">*</span>
                            {% endif %}
                        </label>
                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control', 'id': 'imageFileInput'}}) }}
                        <small class="text-muted">{{ form_help(form.imageFile) }}</small>
                        {{ form_errors(form.imageFile) }}
                        
                        {# Image Preview #}
                        <div id="imagePreview" class="mt-3" style="display: none;">
                            <p class="small text-muted mb-2">Aperçu :</p>
                            <img id="previewImg" src="" alt="Aperçu" class="img-thumbnail" 
                                 style="max-width: 300px; max-height: 300px; object-fit: cover;">
                        </div>
                    </div>
                </div>

                {# Form Actions #}
                <div class="d-flex justify-content-between align-items-center mt-4 pt-4 border-top">
                    <a href="{{ path('my_artworks_list') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-2"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save me-2"></i>
                        {{ action == 'new' ? 'Créer l\'œuvre' : 'Enregistrer les modifications' }}
                    </button>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

<script>
// Image preview
document.getElementById('imageFileInput')?.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('imagePreview').style.display = 'block';
        };
        reader.readAsDataURL(file);
    } else {
        document.getElementById('imagePreview').style.display = 'none';
    }
});
</script>

<style>
.form-control:focus, .form-select:focus {
    border-color: #0d6efd;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
}

.card {
    border-radius: 15px;
}

.btn {
    border-radius: 8px;
}
</style>
{% endblock %}
