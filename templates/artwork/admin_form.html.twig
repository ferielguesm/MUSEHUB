{% extends 'admin/base.html.twig' %}

{% block title %}
    {{ action == 'new' ? 'Nouvelle œuvre' : 'Modifier œuvre' }} - MuseHub Admin
{% endblock %}

{% block body %}
<div class="mb-4 d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
        <a href="{{ path('admin_artwork_index') }}" class="btn btn-link text-decoration-none">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
        <div>
            <h1 class="h3 mb-0">
                {{ action == 'new' ? 'Créer une œuvre' : 'Modifier une œuvre' }}
            </h1>
            <p class="text-muted mb-0">Gérer les œuvres de la plateforme</p>
        </div>
    </div>

    {% if action == 'edit' and artwork %}
    <div class="btn-group" role="group">
        {% if artwork.imageUrl %}
            <a href="https://tineye.com/search?url={{ artwork.imageUrl|url_encode }}" target="_blank"
               class="btn btn-outline-info" title="Vérifier l'image sur TinEye"
               data-bs-toggle="tooltip">
                <i class="fas fa-search-plus me-1"></i>TinEye
            </a>
        {% endif %}

        <a href="https://www.harvardartmuseums.org/collections?search={{ artwork.title|url_encode }}" target="_blank"
           class="btn btn-outline-success" title="Rechercher dans le catalogue Harvard"
           data-bs-toggle="tooltip">
            <i class="fas fa-university me-1"></i>Harvard
        </a>
    </div>
    {% endif %}
</div>

<div class="card" style="border-radius: 15px; border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
    <div class="card-body">
        <form method="POST" action="{{ action == 'new' ? path('admin_artwork_new') : path('admin_artwork_edit', {id: artwork.id}) }}" enctype="multipart/form-data">
            <input type="hidden" name="_token" value="{{ csrf_token(action == 'new' ? 'create_artwork' : 'edit_artwork_' ~ artwork.id) }}">
            <div class="row g-4">
                <div class="col-md-8">
                    <label class="form-label">Titre *</label>
                    <input type="text" name="title" value="{{ artwork ? artwork.title : '' }}" class="form-control" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Artiste UUID *</label>
                    <input type="text" name="artist_uuid" value="{{ artwork ? artwork.artistUuid : '' }}" class="form-control" required placeholder="UUID de l'artiste">
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3" placeholder="Description de l'œuvre">{{ artwork ? artwork.description : '' }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Prix (€)</label>
                    <input type="number" step="0.01" name="price" value="{{ artwork ? artwork.price : '' }}" class="form-control" placeholder="Prix en euros">
                </div>
                <div class="col-md-6">
                    <label class="form-label">Statut</label>
                    <select name="status" class="form-select">
                        <option value="visible" {{ artwork and artwork.status == 'visible' ? 'selected' : '' }}>Visible</option>
                        <option value="hidden" {{ artwork and artwork.status == 'hidden' ? 'selected' : '' }}>Masqué</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Catégorie</label>
                    <select name="category_id" class="form-select">
                        <option value="">Aucune catégorie</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {{ artwork and artwork.category and artwork.category.id == category.id ? 'selected' : '' }}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Image actuelle</label>
                    {% if artwork and artwork.imageUrl %}
                        <div class="mt-2">
                            <img src="{{ artwork.imageUrl }}" alt="Current image" style="max-width: 100px; max-height: 100px; object-fit: cover; border-radius: 8px;">
                            <p class="text-muted small mt-1">{{ artwork.imageUrl }}</p>
                        </div>
                    {% else %}
                        <p class="text-muted small mt-2">Aucune image</p>
                    {% endif %}
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nouvelle image (remplacera l'ancienne)</label>
                    <input type="file" name="image_file" class="form-control" accept="image/png,image/jpeg,image/webp,image/gif">
                    <small class="text-muted">Formats acceptés: JPG, PNG, GIF, WEBP. Taille max: 5MB</small>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ou URL de l'image</label>
                    <input type="url" name="image_url" value="{{ artwork ? artwork.imageUrl : '' }}" class="form-control" placeholder="https://exemple.com/image.jpg">
                    <small class="text-muted">Laissez vide si vous uploadez un fichier</small>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-3 mt-4">
                <a href="{{ path('admin_artwork_index') }}" class="btn btn-outline-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>{{ action == 'new' ? 'Créer' : 'Mettre à jour' }}
                </button>
            </div>
        </form>
    </div>
</div>

<script>
// Initialize tooltips
document.addEventListener('DOMContentLoaded', function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
</script>
{% endblock %}
