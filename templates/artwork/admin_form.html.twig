{% extends 'admin/base.html.twig' %}

{% block title %}
    {{ action == 'new' ? 'Nouvelle œuvre' : 'Modifier œuvre' }} - MuseHub Admin
{% endblock %}

{% block body %}
<div class="mb-4 d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-3">
        <a href="{{ path('admin_artworks_list') }}" class="btn btn-link text-decoration-none">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
        <div>
            <h1 class="h3 mb-0">
                {{ action == 'new' ? 'Créer une œuvre' : 'Modifier une œuvre' }}
            </h1>
            <p class="text-muted mb-0">Gérer les œuvres de la plateforme</p>
        </div>
    </div>

    {% if action == 'edit' and artwork %}
    <div class="btn-group" role="group">
        {% if artwork.imageUrl %}
            <a href="https://tineye.com/search?url={{ artwork.imageUrl|url_encode }}" target="_blank"
               class="btn btn-outline-info" title="Vérifier l'image sur TinEye"
               data-bs-toggle="tooltip">
                <i class="fas fa-search-plus me-1"></i>TinEye
            </a>
        {% endif %}

        <a href="https://www.harvardartmuseums.org/collections?search={{ artwork.title|url_encode }}" target="_blank"
           class="btn btn-outline-success" title="Rechercher dans le catalogue Harvard"
           data-bs-toggle="tooltip">
            <i class="fas fa-university me-1"></i>Harvard
        </a>
    </div>
    {% endif %}
</div>

<div class="card" style="border-radius: 15px; border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
    <div class="card-body">
        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
            <div class="row g-4">
                <div class="col-12">
                    {{ form_label(form.title, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                    <small class="text-muted">{{ form_help(form.title) }}</small>
                    {{ form_errors(form.title) }}
                </div>
                <div class="col-12">
                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                    <small class="text-muted">{{ form_help(form.description) }}</small>
                    {{ form_errors(form.description) }}
                </div>
                <div class="col-md-6">
                    {{ form_label(form.price, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
                    <small class="text-muted">{{ form_help(form.price) }}</small>
                    {{ form_errors(form.price) }}
                </div>
                <div class="col-md-6">
                    {{ form_label(form.category, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                    <small class="text-muted">{{ form_help(form.category) }}</small>
                    {{ form_errors(form.category) }}
                </div>
                <div class="col-12">
                    {{ form_label(form.status, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.status) }}
                    <small class="text-muted d-block mt-2">{{ form_help(form.status) }}</small>
                    {{ form_errors(form.status) }}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Image actuelle</label>
                    {% if artwork and artwork.imageUrl %}
                        <div class="mt-2">
                            <img src="{{ artwork.imageUrl }}" alt="Current image" style="max-width: 150px; max-height: 150px; object-fit: cover; border-radius: 8px; border: 2px solid #dee2e6;">
                            <p class="text-muted small mt-1">{{ artwork.imageUrl }}</p>
                        </div>
                    {% else %}
                        <p class="text-muted small mt-2">Aucune image</p>
                    {% endif %}
                </div>
                <div class="col-md-6">
                    {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                    <small class="text-muted">{{ form_help(form.imageFile) }}</small>
                    {{ form_errors(form.imageFile) }}
                </div>
            </div>
            <div class="d-flex justify-content-end gap-3 mt-4">
                <a href="{{ path('admin_artworks_list') }}" class="btn btn-outline-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>{{ action == 'new' ? 'Créer' : 'Mettre à jour' }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>

<script>
// Initialize tooltips
document.addEventListener('DOMContentLoaded', function() {
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
});
</script>
{% endblock %}
